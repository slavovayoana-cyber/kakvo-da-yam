{
  "expo": {
    "name": "Какво да ям?",
    "slug": "kakvo-da-yam-app",
    "version": "1.0.0",
    "orientation": "portrait",
    "icon": "./assets/icon.png",
    "userInterfaceStyle": "light",
    "newArchEnabled": true,
    "splash": {
      "image": "./assets/splash-icon.png",
      "resizeMode": "contain",
      "backgroundColor": "#D5918A"
    },
    "ios": {
      "supportsTablet": true,
      "bundleIdentifier": "com.kakvodayam.app",
      "infoPlist": {
        "ITSAppUsesNonExemptEncryption": false,
        "LSApplicationQueriesSchemes": ["comgooglemaps"]
      }
    },
    "android": {
      "package": "com.kakvodayam.app",
      "adaptiveIcon": {
        "foregroundImage": "./assets/adaptive-icon.png",
        "backgroundColor": "#D5918A"
      },
      "edgeToEdgeEnabled": true,
      "predictiveBackGestureEnabled": false
    },
    "web": {
      "favicon": "./assets/favicon.png"
    },
    "plugins": [
      "expo-font"
    ],
    "extra": {
      "eas": {
        "projectId": "0e13e17d-cac9-434b-8a46-9424eeef19be"
      }
    },
    "owner": "slavovayoana",
    "runtimeVersion": {
      "policy": "appVersion"
    },
    "updates": {
      "url": "https://u.expo.dev/0e13e17d-cac9-434b-8a46-9424eeef19be"
    }
  }
}
