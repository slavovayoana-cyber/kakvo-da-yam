{
  "expo": {
    "name": "Какво да ям?",
    "slug": "kakvodayam",
    "version": "1.0.0",
    "orientation": "portrait",
    "icon": "./assets/icon.png",
    "userInterfaceStyle": "light",
    "newArchEnabled": true,
    "splash": {
      "image": "./assets/splash-icon.png",
      "resizeMode": "contain",
      "backgroundColor": "#FBF7F2"
    },
    "ios": {
      "supportsTablet": true,
      "bundleIdentifier": "com.kakvodayam.app",
      "infoPlist": {
        "NSMotionUsageDescription": "Заровете на началния екран се движат лекичко спрямо как държиш телефона."
      }
    },
    "android": {
      "package": "com.kakvodayam.app",
      "adaptiveIcon": {
        "foregroundImage": "./assets/adaptive-icon.png",
        "backgroundColor": "#FBF7F2"
      },
      "edgeToEdgeEnabled": true,
      "predictiveBackGestureEnabled": false
    },
    "web": {
      "favicon": "./assets/favicon.png"
    },
    "plugins": [
      "expo-font"
    ]
  }
}
